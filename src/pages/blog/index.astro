---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const posts = [
  {
    date: '2024-03-15',
    tag: 'Legislativo',
    title: 'A Regulação de IA no Senado Brasileiro',
    summary: 'O que dizem as propostas de emendas constitucionais sobre inteligência artificial? Uma análise de rede das posições parlamentares.',
    readTime: '8 min',
  },
  {
    date: '2024-01-20',
    tag: 'Redes',
    title: 'Genealogia Acadêmica e Análise de Redes',
    summary: 'Como mapear a trajetória intelectual de um campo científico usando grafos de co-orientação e co-autoria.',
    readTime: '6 min',
  },
  {
    date: '2023-11-10',
    tag: 'NLP',
    title: 'Ensinando o Computador a Ler Atas Parlamentares',
    summary: 'Um guia prático de pré-processamento de texto legislativo em português com Python e spaCy.',
    readTime: '12 min',
  },
  {
    date: '2023-08-22',
    tag: 'Análise de Redes',
    title: 'Redes de Audiências no Senado: Uma Análise Visual',
    summary: 'Visualização e análise da rede de participações em audiências públicas do Senado Federal entre 2019 e 2023.',
    readTime: '7 min',
  },
  {
    date: '2023-03-05',
    tag: 'Dados',
    title: 'Ainda Estou Aqui: Uma Análise dos Discursos do Oscar',
    summary: 'Usando NLP e análise de sentimento para mapear os temas e padrões nos discursos de aceitação do Oscar.',
    readTime: '10 min',
  },
];
---

<Layout title="Blog" description="Posts sobre análise de redes, NLP, ciência de dados e inovação por Vinicius Santos.">

  <section class="pt-32 pb-20 bg-navy-900">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-accent-cyan text-sm font-mono uppercase tracking-widest mb-4">Blog</p>
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
        Network Thinking
      </h1>
      <p class="text-gray-400 text-xl max-w-2xl">
        Posts técnicos acessíveis sobre análise de redes, NLP e ciência de dados aplicada a problemas reais.
      </p>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <div class="space-y-12">
        {posts.map(post => (
          <article class="group border-b border-gray-100 pb-12 last:border-0">
            <div class="flex items-center gap-3 mb-3">
              <span class="px-2 py-0.5 bg-blue-50 text-accent text-xs font-medium rounded">{post.tag}</span>
              <span class="text-xs text-gray-400 font-mono">
                {new Date(post.date).toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
              <span class="text-xs text-gray-400">· {post.readTime}</span>
            </div>
            <h2 class="text-2xl font-bold text-navy-900 mb-3 group-hover:text-accent transition-colors">
              <a href="#">{post.title}</a>
            </h2>
            <p class="text-gray-600 leading-relaxed mb-4">{post.summary}</p>
            <a href="#" class="text-sm text-accent font-medium hover:underline">Ler artigo →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

</Layout>
