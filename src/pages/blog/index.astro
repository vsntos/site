---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Blog" description="Posts sobre análise de redes, NLP, ciência de dados e inovação por Vinicius Santos.">

  <section class="pt-32 pb-20 bg-navy-900">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-accent-cyan text-sm font-mono uppercase tracking-widest mb-4">Blog</p>
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">Network Thinking</h1>
      <p class="text-gray-400 text-xl max-w-2xl">
        Posts técnicos acessíveis sobre análise de redes, NLP e ciência de dados aplicada a problemas reais.
      </p>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <div class="space-y-12">
        {posts.map(post => (
          <article class="group border-b border-gray-100 pb-12 last:border-0">
            <div class="flex items-center gap-3 mb-3">
              <span class="px-2 py-0.5 bg-blue-50 text-accent text-xs font-medium rounded">{post.data.tag}</span>
              <span class="text-xs text-gray-400 font-mono">
                {post.data.date.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
              <span class="text-xs text-gray-400">· {post.data.readTime}</span>
            </div>
            <h2 class="text-2xl font-bold text-navy-900 mb-3 group-hover:text-accent transition-colors">
              <a href={`${base}/blog/${post.slug}/`}>{post.data.title}</a>
            </h2>
            <p class="text-gray-600 leading-relaxed mb-4">{post.data.summary}</p>
            <a href={`${base}/blog/${post.slug}/`} class="text-sm text-accent font-medium hover:underline">Ler artigo →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

</Layout>
