---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.summary}>

  <section class="pt-32 pb-12 bg-navy-900">
    <div class="max-w-3xl mx-auto px-6">
      <a href={`${base}/blog/`} class="text-accent-cyan text-sm font-mono hover:underline mb-8 block">← Blog</a>
      <div class="flex items-center gap-3 mb-4">
        <span class="px-2 py-0.5 bg-white/10 text-accent-cyan text-xs font-medium rounded">{post.data.tag}</span>
        <span class="text-xs text-gray-400 font-mono">
          {post.data.date.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
        <span class="text-xs text-gray-400">· {post.data.readTime}</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight">{post.data.title}</h1>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-xl text-gray-500 leading-relaxed mb-12 border-l-4 border-accent pl-4">{post.data.summary}</p>
      <div class="prose prose-lg prose-blue max-w-none">
        <Content />
      </div>
    </div>
  </section>

</Layout>
