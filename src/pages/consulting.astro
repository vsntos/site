---
import Layout from '../layouts/Layout.astro';
import MiniNetwork from '../components/MiniNetwork.jsx';
const base = import.meta.env.BASE_URL;
---

<Layout title="Consultoria" description="Consultoria em análise de redes, monitoramento legislativo e ecossistemas de inovação para empresas e governos.">

  <!-- Header -->
  <section class="pt-32 pb-20 bg-navy-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background: radial-gradient(ellipse at 70% 50%, #06b6d4 0%, transparent 60%)"></div>
    <div class="relative z-10 max-w-6xl mx-auto px-6">
      <p class="text-accent-cyan text-sm font-mono uppercase tracking-widest mb-4">Consultoria</p>
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 max-w-3xl">
        Decisões estratégicas baseadas em evidência
      </h1>
      <p class="text-gray-400 text-xl max-w-2xl leading-relaxed">
        Para organizações que operam em ambientes de alta incerteza e precisam enxergar o que a análise convencional não consegue.
      </p>
    </div>
  </section>

  <!-- Serviços -->
  <section class="bg-stone-50">
    <div class="max-w-6xl mx-auto px-6 pt-20 pb-4">
      <h2 class="text-5xl md:text-7xl font-bold text-navy-900 tracking-tight">SERVIÇOS</h2>
    </div>

    {[
      {
        num: '01',
        title: 'MAPEAMENTO DE ECOSSISTEMAS',
        description: 'Identificação de atores, conexões e fluxos de conhecimento em ecossistemas de startups, clusters industriais e redes de P&D. Você vê quem realmente importa — não quem aparece nos organogramas.',
        seed: 2,
      },
      {
        num: '02',
        title: 'MONITORAMENTO LEGISLATIVO',
        description: 'Processamento de linguagem natural aplicado a dados legislativos para rastrear agendas, coalizões e posicionamentos em tempo real. Pare de ler atas — comece a ler a rede.',
        seed: 5,
      },
      {
        num: '03',
        title: 'REDES ORGANIZACIONAIS',
        description: 'Mapeamento de colaboração, comunicação e influência dentro e entre organizações. Identifique pontes, grupos e líderes informais que os dados de RH não mostram.',
        seed: 8,
      },
      {
        num: '04',
        title: 'TREINAMENTOS & WORKSHOPS',
        description: 'Formação em ciência de redes aplicada, NLP e análise de dados para equipes técnicas e de gestão. Do básico ao avançado, com casos reais do contexto brasileiro.',
        seed: 11,
      },
    ].map(service => (
      <div class="group border-t border-stone-200 last:border-b">
        <div class="max-w-6xl mx-auto px-6 grid grid-cols-12 gap-6 items-center py-8 hover:bg-stone-100 transition-colors duration-200 cursor-default">

          <!-- Número -->
          <div class="col-span-1 hidden md:block">
            <span class="text-xs font-mono text-stone-400">({service.num})</span>
          </div>

          <!-- Título -->
          <div class="col-span-12 md:col-span-3">
            <h3 class="text-xl md:text-2xl font-bold text-navy-900 tracking-tight leading-tight group-hover:text-accent transition-colors duration-200">
              {service.title}
            </h3>
          </div>

          <!-- Network visual -->
          <div class="col-span-12 md:col-span-3 h-36 rounded-xl overflow-hidden bg-navy-900">
            <MiniNetwork client:visible seed={service.seed} hovered={true} />
          </div>

          <!-- Descrição -->
          <div class="col-span-12 md:col-span-4">
            <p class="text-stone-600 text-sm leading-relaxed">{service.description}</p>
          </div>

          <!-- Seta -->
          <div class="col-span-12 md:col-span-1 flex md:justify-end">
            <a href={`#agendar`}
               class="w-10 h-10 rounded-full bg-navy-900 flex items-center justify-center group-hover:bg-accent transition-colors duration-200 flex-shrink-0">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </a>
          </div>

        </div>
      </div>
    ))}
  </section>

  <!-- Como funciona -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-accent text-sm font-mono uppercase tracking-widest mb-4">Processo</p>
      <h2 class="text-3xl font-bold text-navy-900 mb-16">Como trabalhamos juntos</h2>
      <div class="grid md:grid-cols-4 gap-8">
        {[
          { step: '01', title: 'Conversa inicial', desc: 'Entendemos o problema, o contexto e o que uma boa resposta precisa incluir.' },
          { step: '02', title: 'Coleta e modelagem', desc: 'Identificamos as fontes de dados e construímos a estrutura de rede adequada.' },
          { step: '03', title: 'Análise e visualização', desc: 'Rodamos as análises e construímos visualizações que comunicam os resultados.' },
          { step: '04', title: 'Entrega e ação', desc: 'Relatório, dashboard ou apresentação — no formato que sua equipe vai usar.' },
        ].map(item => (
          <div class="relative">
            <p class="text-6xl font-bold text-gray-100 mb-4">{item.step}</p>
            <h3 class="font-bold text-lg text-navy-900 mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Booking -->
  <section id="agendar" class="py-24 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-accent text-sm font-mono uppercase tracking-widest mb-4">Agendar</p>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-4">
          Vamos conversar sobre seu projeto
        </h2>
        <p class="text-gray-600 text-lg leading-relaxed">
          A primeira conversa é gratuita e sem compromisso. Em 30 minutos avaliamos se faz sentido trabalharmos juntos.
        </p>
      </div>

      <!-- Cal.com inline widget -->
      <div id="cal-inline" class="rounded-2xl overflow-hidden border border-gray-100 shadow-sm" style="min-height:600px;"></div>
    </div>
  </section>

  <script type="text/javascript">
    (function(C,A,L){
      let p=function(a,ar){a.q.push(ar);};
      let d=C.document;
      C.Cal=C.Cal||function(){
        let cal=C.Cal;let ar=arguments;
        if(!cal.loaded){cal.ns={};cal.q=cal.q||[];d.head.appendChild(d.createElement("script")).src=A;cal.loaded=true;}
        if(ar[0]===L){const api=function(){p(api,arguments);};const namespace=ar[1];api.q=api.q||[];if(typeof namespace==="string"){cal.ns[namespace]=cal.ns[namespace]||api;p(cal.ns[namespace],ar);p(cal,["-",namespace,ar]);}else{p(cal,ar);}return;}
        p(cal,ar);
      };
    })(window,"https://app.cal.com/embed/embed.js","init");

    Cal("init", { origin: "https://app.cal.com" });
    Cal("inline", {
      elementOrSelector: "#cal-inline",
      calLink: "vinicius-santos",
    });
    Cal("ui", {
      theme: "light",
      styles: { branding: { brandColor: "#2563eb" } },
      hideEventTypeDetails: false,
      layout: "month_view",
    });
  </script>

</Layout>
