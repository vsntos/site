---
import Layout from '../layouts/Layout.astro';
import NetworkHero from '../components/NetworkHero.jsx';
import CaseCard from '../components/CaseCard.jsx';
import SectionNetwork from '../components/SectionNetwork.jsx';
const base = import.meta.env.BASE_URL;
---

<Layout title="Home" description="Vinicius Santos — O que os dados não mostram, a rede revela. Cientista social computacional especializado em análise de redes e inovação.">

  <!-- Hero -->
  <section class="relative min-h-screen bg-navy-900 flex items-center overflow-hidden">
    <NetworkHero client:load />

    <div class="relative z-10 max-w-6xl mx-auto px-6 py-32">
      <p class="text-accent-cyan text-sm font-mono uppercase tracking-widest mb-8 opacity-0 animate-fade-up" style="animation-fill-mode:forwards">
        Cientista Social Computacional
      </p>
      <h1 class="text-5xl md:text-7xl font-bold text-white leading-[1.05] mb-8 opacity-0 animate-fade-up" style="animation-delay:0.1s;animation-fill-mode:forwards">
        O que os dados<br/>não mostram,<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-accent-cyan">
          a rede revela.
        </span>
      </h1>
      <p class="text-gray-400 text-xl max-w-xl leading-relaxed mb-4 opacity-0 animate-fade-up" style="animation-delay:0.2s;animation-fill-mode:forwards">
        Eu transformo dados complexos em mapas estratégicos —
        do dado bruto à decisão, sem intermediários.
      </p>
      <p class="text-gray-600 text-sm mb-12 opacity-0 animate-fade-up" style="animation-delay:0.25s;animation-fill-mode:forwards">
        ↑ passe o mouse nos nós azuis
      </p>
      <div class="flex flex-col sm:flex-row gap-4 opacity-0 animate-fade-up" style="animation-delay:0.3s;animation-fill-mode:forwards">
        <a href={`${base}/cases`} class="inline-flex items-center justify-center px-8 py-4 bg-accent text-white font-semibold rounded-lg hover:bg-blue-600 transition-all hover:scale-105 hover:shadow-lg hover:shadow-accent/25">
          Ver projetos
        </a>
        <a href={`${base}/consulting`} class="inline-flex items-center justify-center px-8 py-4 border border-gray-600 text-gray-300 font-semibold rounded-lg hover:border-accent hover:text-accent transition-all">
          Falar sobre consultoria
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-gray-500 animate-bounce">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- Scroll narrativo: o problema -->
  <section class="py-32 bg-white scroll-section" data-section="0">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-20 items-center">
        <div class="scroll-content">
          <span class="inline-block px-3 py-1 bg-red-50 text-red-500 text-xs font-mono rounded-full mb-6">01 — O problema</span>
          <h2 class="text-4xl md:text-5xl font-bold text-navy-900 leading-tight mb-6">
            Você tem o problema. Os dados têm a resposta. Eu faço a conexão.
          </h2>
          <p class="text-gray-600 text-lg leading-relaxed">
            Hierarquias formais, relatórios e planilhas mostram o que deveria existir.
            Redes expõem o que os dados não dizem sozinhos — quem realmente decide, onde o conhecimento circula, onde a cadeia vai quebrar.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4 scroll-content" style="animation-delay:0.15s">
          {[
            { label: 'O que você vê', items: ['Organograma', 'Relatório mensal', 'Ata da reunião', 'Planilha de dados'], icon: '📋', muted: true },
            { label: 'O que existe', items: ['Rede de influência', 'Fluxo de conhecimento', 'Coalização informal', 'Estrutura de poder'], icon: '🔬', muted: false },
          ].map(col => (
            <div class={`p-5 rounded-2xl ${col.muted ? 'bg-gray-50 border border-gray-100' : 'bg-navy-900 border border-accent/20'}`}>
              <p class={`text-xs font-mono mb-4 ${col.muted ? 'text-gray-400' : 'text-accent-cyan'}`}>{col.label}</p>
              <ul class="space-y-2">
                {col.items.map(item => (
                  <li class={`text-sm ${col.muted ? 'text-gray-400 line-through' : 'text-gray-200'} flex items-center gap-2`}>
                    <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" class:list={[col.muted ? 'bg-gray-300' : 'bg-accent']}></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Scroll narrativo: os dados -->
  <section class="py-32 bg-gray-50 scroll-section" data-section="1">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-20 items-center">
        <div class="order-2 md:order-1">
          <div class="grid grid-cols-3 gap-3 scroll-content">
            {[
              { env: 'Parlamento', trace: 'Votações & atas', color: 'bg-blue-50 border-blue-100' },
              { env: 'Ecossistema', trace: 'Contratos & parcerias', color: 'bg-violet-50 border-violet-100' },
              { env: 'Pesquisa', trace: 'Co-autorias & orientações', color: 'bg-emerald-50 border-emerald-100' },
              { env: 'Inovação', trace: 'Patentes & registros', color: 'bg-orange-50 border-orange-100' },
              { env: 'Organizações', trace: 'Audiências & participações', color: 'bg-cyan-50 border-cyan-100' },
              { env: 'Governo', trace: 'Licitações & projetos', color: 'bg-rose-50 border-rose-100' },
            ].map(item => (
              <div class={`p-4 rounded-xl border ${item.color} text-center`}>
                <p class="text-sm font-semibold text-gray-800 mb-1">{item.env}</p>
                <p class="font-mono text-xs text-gray-500 leading-snug">{item.trace}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="order-1 md:order-2 scroll-content" style="animation-delay:0.15s">
          <span class="inline-block px-3 py-1 bg-blue-50 text-accent text-xs font-mono rounded-full mb-6">02 — Os dados</span>
          <h2 class="text-4xl md:text-5xl font-bold text-navy-900 leading-tight mb-6">
            Cada votação, email e patente deixa um rastro.
          </h2>
          <p class="text-gray-600 text-lg leading-relaxed">
            Esses rastros existem em qualquer organização, parlamento ou ecossistema.
            O trabalho começa antes dos dados — na identificação de onde eles estão.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Scroll narrativo: a rede -->
  <section class="py-32 bg-navy-900 scroll-section" data-section="2">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-20 items-center">
        <div class="scroll-content">
          <span class="inline-block px-3 py-1 bg-accent/10 text-accent text-xs font-mono rounded-full mb-6">03 — A rede</span>
          <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
            Conectados, os rastros viram um mapa.
          </h2>
          <p class="text-gray-400 text-lg leading-relaxed mb-8">
            Análise de redes revela o que a estatística clássica não consegue:
            a estrutura. Quem conecta quem. Onde está o gargalo. Quem tem poder sem aparecer no organograma.
          </p>
          <div class="grid grid-cols-3 gap-4">
            {[
              { metric: 'Centralidade', desc: 'Quem realmente importa' },
              { metric: 'Brokers', desc: 'Quem conecta mundos separados' },
              { metric: 'Clusters', desc: 'Onde estão os silos' },
            ].map(m => (
              <div class="p-4 rounded-xl bg-navy-800 border border-navy-700">
                <p class="text-accent text-sm font-semibold mb-1">{m.metric}</p>
                <p class="text-gray-500 text-xs">{m.desc}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="scroll-content rounded-2xl border border-navy-700 overflow-hidden relative" style="animation-delay:0.15s; aspect-ratio:1">
          <div class="absolute inset-0" style="background:radial-gradient(circle at 50% 50%, rgba(59,130,246,0.12) 0%, transparent 70%)"></div>
          <SectionNetwork client:visible seed={7} />
          <div class="absolute bottom-0 left-0 right-0 p-5 bg-gradient-to-t from-navy-900 to-transparent">
            <p class="text-white font-semibold text-sm">Estrutura visível</p>
            <p class="text-gray-500 text-xs mt-1">Conexões que não aparecem em nenhum relatório</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Scroll narrativo: a decisão -->
  <section class="py-32 bg-white scroll-section" data-section="3">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-block px-3 py-1 bg-emerald-50 text-emerald-600 text-xs font-mono rounded-full mb-6">04 — A decisão</span>
        <h2 class="text-4xl md:text-5xl font-bold text-navy-900 leading-tight mb-6">
          O mapa vira estratégia.
        </h2>
        <p class="text-gray-600 text-xl leading-relaxed mb-16">
          Não entrego relatório. Entrego clareza.<br/>
          Uma posição diferente numa comissão. Um parceiro que ninguém via. Uma conexão que muda o jogo.
        </p>

        <div class="grid grid-cols-3 gap-8 mb-16">
          {[
            { number: '14', label: 'anos de dados legislativos processados', suffix: '' },
            { number: '9', label: 'publicações em periódicos internacionais', suffix: '+' },
            { number: '100', label: 'de domínio do ciclo de dados', suffix: '%' },
          ].map(stat => (
            <div class="text-center">
              <p class="text-5xl font-bold text-navy-900 mb-2">{stat.number}<span class="text-accent">{stat.suffix}</span></p>
              <p class="text-gray-500 text-sm leading-snug">{stat.label}</p>
            </div>
          ))}
        </div>

        <a href={`${base}/consulting`} class="inline-flex items-center px-10 py-5 bg-navy-900 text-white font-semibold text-lg rounded-xl hover:bg-navy-800 transition-all hover:scale-105 hover:shadow-xl">
          Quero esse mapa para minha organização →
        </a>
      </div>
    </div>
  </section>

  <!-- Cases -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-accent text-sm font-mono uppercase tracking-widest mb-2">Cases</p>
          <h2 class="text-3xl font-bold text-navy-900">Projetos recentes</h2>
        </div>
        <a href={`${base}/cases`} class="text-sm text-accent hover:underline hidden md:block">Ver todos →</a>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <CaseCard
          client:visible
          seed={1}
          tag="Governo"
          title="Monitoramento Legislativo com NLP"
          summary="14 anos de notas taquigráficas do Senado mapeadas para orientar posicionamento parlamentar."
          metrics={['14 anos', 'NLP', 'Redes']}
          href={`${base}/cases`}
        />
        <CaseCard
          client:visible
          seed={42}
          tag="Inovação"
          title="Ecossistema de Startups"
          summary="Rede de colaboração entre startups, investidores e universidades para identificar atores estratégicos."
          metrics={['200+ atores', 'Bipartida', 'Estratégia']}
          href={`${base}/cases`}
        />
        <CaseCard
          client:visible
          seed={7}
          tag="P&D"
          title="Redes de Co-Patentes"
          summary="Mapeamento de fluxos de conhecimento tecnológico via análise de co-autoria de patentes do INPI."
          metrics={['INPI', 'Temporal', 'Dashboard']}
          href={`${base}/cases`}
        />
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-24 bg-navy-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background:radial-gradient(ellipse at 30% 50%, #3b82f6 0%, transparent 60%)"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <p class="text-accent-cyan text-sm font-mono uppercase tracking-widest mb-4">Próximo passo</p>
      <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">
        Qual mapa a sua<br/>organização está faltando?
      </h2>
      <p class="text-gray-400 text-xl mb-12 max-w-2xl mx-auto">
        30 minutos de conversa são suficientes para eu entender o problema e dizer se consigo ajudar.
      </p>
      <a href={`${base}/consulting`} class="inline-flex items-center px-10 py-5 bg-accent text-white font-semibold text-lg rounded-xl hover:bg-blue-600 transition-all hover:scale-105 hover:shadow-2xl hover:shadow-accent/30">
        Agendar conversa gratuita
      </a>
    </div>
  </section>

</Layout>

<script>
  // Scroll animations with Intersection Observer
  const sections = document.querySelectorAll('.scroll-section');
  const contents = document.querySelectorAll('.scroll-content');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll('.scroll-content').forEach(el => {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        });
      }
    });
  }, { threshold: 0.15 });

  sections.forEach(section => {
    section.querySelectorAll('.scroll-content').forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(30px)';
      el.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
      const delay = el.getAttribute('style')?.match(/animation-delay:([\d.]+)s/)?.[1];
      if (delay) el.style.transitionDelay = `${delay}s`;
    });
    observer.observe(section);
  });
</script>
