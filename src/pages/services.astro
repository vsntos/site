---
import Layout from '../layouts/Layout.astro';
import MiniNetwork from '../components/MiniNetwork.jsx';
const base = import.meta.env.BASE_URL;

const tecnicas = [
  { id: 'redes',       label: 'Análise de Redes',              desc: 'Centralidade, comunidades, brokers, fluxos de influência' },
  { id: 'texto',       label: 'Análise de Texto & Semântica',  desc: 'NLP, embeddings, modelagem de tópicos, similaridade semântica' },
  { id: 'issue',       label: 'Issue Mapping',                 desc: 'Mapeamento de posições de atores em temas regulatórios, políticos e setoriais' },
  { id: 'naoestruturado', label: 'Dados Digitais Não Estruturados', desc: 'Extração de informação de PDFs, atas, pareceres, contratos e documentos escaneados' },
  { id: 'geo',         label: 'Dados Geoespaciais & Mapas',    desc: 'Análise espacial, distribuição territorial, cartografia de dados' },
  { id: 'temporal',    label: 'Análise Temporal',              desc: 'Séries temporais, análise de sobrevivência, duração de processos' },
  { id: 'coleta',      label: 'Coleta de Dados Públicos',      desc: 'APIs legislativas, dados abertos, scraping, estruturação de fontes' },
  { id: 'viz',         label: 'Visualização & Dashboards',     desc: 'Dashboards interativos, relatórios visuais, comunicação de resultados' },
];

const temas = [
  { id: 'legislativo', label: 'Parlamento & Legislativo' },
  { id: 'ecosistema',  label: 'Ecossistemas de Inovação & P&D' },
  { id: 'civictech',   label: 'Civic Tech & Governança de Dados' },
  { id: 'relgov',      label: 'Relações Governamentais' },
];

// true = capacidade ativa, false = fora do escopo
const matriz: Record<string, Record<string, boolean>> = {
  redes:          { legislativo: true,  ecosistema: true,  civictech: true,  relgov: true  },
  texto:          { legislativo: true,  ecosistema: true,  civictech: true,  relgov: true  },
  issue:          { legislativo: true,  ecosistema: true,  civictech: true,  relgov: true  },
  naoestruturado: { legislativo: true,  ecosistema: true,  civictech: true,  relgov: true  },
  geo:            { legislativo: true,  ecosistema: true,  civictech: true,  relgov: true  },
  temporal:       { legislativo: true,  ecosistema: true,  civictech: false, relgov: true  },
  coleta:         { legislativo: true,  ecosistema: true,  civictech: true,  relgov: true  },
  viz:            { legislativo: true,  ecosistema: true,  civictech: true,  relgov: true  },
};

const servicos = [
  {
    num: '01',
    title: 'MAPEAMENTO DE ECOSSISTEMAS',
    tecnica: 'Análise de Redes',
    tema: 'Ecossistemas de Inovação',
    description: 'Identificação de atores, conexões e fluxos de conhecimento em ecossistemas de startups, clusters industriais e redes de P&D.',
    deliverables: ['Mapa de atores-chave', 'Análise de centralidade', 'Relatório estratégico'],
    seed: 2,
  },
  {
    num: '02',
    title: 'MONITORAMENTO LEGISLATIVO',
    tecnica: 'NLP + Redes',
    tema: 'Parlamento & Legislativo',
    description: 'Processamento de linguagem natural aplicado a dados legislativos para rastrear agendas, coalizões e posicionamentos.',
    deliverables: ['Dashboard de votações', 'Mapa de coalizões', 'Alertas temáticos'],
    seed: 5,
  },
  {
    num: '03',
    title: 'INTELIGÊNCIA REGULATÓRIA',
    tecnica: 'Texto & Semântica + Redes',
    tema: 'Relações Governamentais',
    description: 'Monitoramento de agendas regulatórias, mapeamento de stakeholders institucionais e análise de posicionamento em processos de consulta pública e regulação setorial.',
    deliverables: ['Radar regulatório', 'Mapa de stakeholders', 'Notas de posicionamento'],
    seed: 8,
  },
  {
    num: '04',
    title: 'TREINAMENTOS & WORKSHOPS',

    tecnica: 'Múltiplas técnicas',
    tema: 'Qualquer domínio',
    description: 'Formação em ciência de redes aplicada, NLP e análise de dados para equipes técnicas e de gestão.',
    deliverables: ['Material didático', 'Exercícios práticos', 'Casos reais brasileiros'],
    seed: 11,
  },
];
---

<Layout title="Serviços" description="Serviços de consultoria em análise de redes, NLP e ciência de dados aplicada por Vinicius Santos.">

  <!-- Header editorial -->
  <section class="pt-32 pb-0 bg-stone-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-start justify-between mb-16">
        <div class="flex items-center gap-2 pt-2">
          <span class="w-2 h-2 bg-navy-900 rounded-none inline-block"></span>
          <span class="text-xs font-mono uppercase tracking-widest text-navy-900">Serviços</span>
        </div>
        <h1 class="text-5xl md:text-8xl font-bold text-navy-900 tracking-tight leading-none text-right">
          O QUE<br/>FAZEMOS.
        </h1>
      </div>
    </div>
  </section>

  <!-- Dois eixos -->
  <section class="bg-stone-50 pb-16">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12">

      <!-- Técnicas -->
      <div class="mt-10">
        <p class="text-xs font-mono uppercase tracking-widest text-accent mb-6">Técnicas</p>
        <div class="grid grid-cols-2 gap-3">
          {tecnicas.map(t => (
            <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-stone-100">
              <span class="w-2 h-2 rounded-full bg-accent mt-1.5 flex-shrink-0"></span>
              <div>
                <p class="font-bold text-navy-900 text-sm leading-snug">{t.label}</p>
                <p class="text-xs text-stone-400 font-mono mt-1 leading-snug">{t.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Domínios -->
      <div class="mt-10">
        <p class="text-xs font-mono uppercase tracking-widest text-accent mb-6">Domínios</p>
        <div class="space-y-3">
          {temas.map(t => (
            <div class="flex items-center gap-4 p-5 bg-white rounded-xl border border-stone-100">
              <span class="w-2 h-2 rounded-full bg-navy-900 flex-shrink-0"></span>
              <p class="font-bold text-navy-900 text-sm">{t.label}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- Matriz técnicas × temas -->
  <section class="bg-white py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-2">Cobertura</p>
      <h2 class="text-2xl font-bold text-navy-900 mb-12">Técnicas × Domínios</h2>

      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr>
              <th class="text-left pb-4 pr-8 w-48"></th>
              {temas.map(t => (
                <th class="text-center pb-4 px-4 min-w-[130px]">
                  <span class="text-xs font-mono text-stone-400 uppercase tracking-wider leading-tight block">{t.label}</span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {tecnicas.map((tec, ri) => (
              <tr class={ri % 2 === 0 ? 'bg-stone-50' : 'bg-white'}>
                <td class="py-5 pr-8">
                  <p class="font-bold text-sm text-navy-900">{tec.label}</p>
                </td>
                {temas.map(tema => (
                  <td class="py-5 px-4 text-center">
                    {matriz[tec.id][tema.id] ? (
                      <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-accent/10 mx-auto">
                        <span class="w-3 h-3 rounded-full bg-accent block"></span>
                      </span>
                    ) : (
                      <span class="inline-flex items-center justify-center w-8 h-8 mx-auto">
                        <span class="w-3 h-3 rounded-full bg-stone-200 block"></span>
                      </span>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>

        <div class="flex items-center gap-6 mt-6">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-accent inline-block"></span>
            <span class="text-xs text-stone-500 font-mono">capacidade ativa</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-stone-200 inline-block"></span>
            <span class="text-xs text-stone-500 font-mono">fora do escopo</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Serviços como aplicações da matriz -->
  <section class="bg-stone-50 pb-0">
    <div class="max-w-6xl mx-auto px-6 pt-20 pb-4">
      <p class="text-xs font-mono uppercase tracking-widest text-accent mb-2">Aplicações</p>
      <h2 class="text-2xl font-bold text-navy-900 mb-0">Serviços disponíveis</h2>
    </div>

    {servicos.map(service => (
      <div class="group border-t border-stone-200 last:border-b">
        <div class="max-w-6xl mx-auto px-6 grid grid-cols-12 gap-6 items-center py-10 hover:bg-stone-100 transition-colors duration-200 cursor-default">

          <div class="col-span-1 hidden md:block">
            <span class="text-xs font-mono text-stone-400">({service.num})</span>
          </div>

          <div class="col-span-12 md:col-span-3">
            <h3 class="text-xl font-bold text-navy-900 tracking-tight leading-tight group-hover:text-accent transition-colors duration-200 mb-3">
              {service.title}
            </h3>
            <div class="flex flex-wrap gap-1.5">
              <span class="px-2 py-0.5 bg-accent/10 text-accent text-xs font-mono rounded">{service.tecnica}</span>
              <span class="px-2 py-0.5 bg-navy-900/5 text-navy-900 text-xs font-mono rounded">{service.tema}</span>
            </div>
          </div>

          <div class="col-span-12 md:col-span-3 h-40 rounded-xl overflow-hidden bg-navy-900">
            <MiniNetwork client:visible seed={service.seed} hovered={true} />
          </div>

          <div class="col-span-12 md:col-span-3">
            <p class="text-stone-600 text-sm leading-relaxed mb-4">{service.description}</p>
            <ul class="space-y-1">
              {service.deliverables.map(d => (
                <li class="flex items-center gap-2 text-xs text-stone-400 font-mono">
                  <span class="w-1 h-1 rounded-full bg-accent inline-block flex-shrink-0"></span>
                  {d}
                </li>
              ))}
            </ul>
          </div>

          <div class="col-span-12 md:col-span-2 flex md:justify-end">
            <a href={`${base}/consulting#agendar`}
               class="inline-flex items-center gap-2 text-xs font-mono text-stone-400 group-hover:text-accent transition-colors duration-200">
              Agendar
              <span class="w-8 h-8 rounded-full bg-navy-900 flex items-center justify-center group-hover:bg-accent transition-colors duration-200 flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </span>
            </a>
          </div>

        </div>
      </div>
    ))}
  </section>

  <!-- CTA -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold text-navy-900 mb-4">Seu problema está na matriz?</h2>
      <p class="text-gray-600 mb-8">Se a combinação técnica + domínio que você precisa está coberta, a conversa vale 30 minutos.</p>
      <a href={`${base}/consulting#agendar`} class="inline-flex items-center px-8 py-4 bg-accent text-white font-semibold rounded-xl hover:bg-blue-600 transition-colors">
        Agendar conversa gratuita
      </a>
    </div>
  </section>

</Layout>
