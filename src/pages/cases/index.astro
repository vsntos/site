---
import Layout from '../../layouts/Layout.astro';
import MiniNetwork from '../../components/MiniNetwork.jsx';
const base = import.meta.env.BASE_URL;

const cases = [
  {
    seed: 1,
    tag: 'Governo',
    tagColor: 'bg-blue-50 text-blue-600',
    title: 'Monitoramento Legislativo com NLP',
    summary: 'Processamento de 14 anos de notas taquigráficas do Senado Federal para mapear coalizões e orientar posicionamento parlamentar.',
    metrics: ['14 anos de dados', '27 comissões', 'NLP + redes'],
  },
  {
    seed: 4,
    tag: 'Inovação',
    tagColor: 'bg-violet-50 text-violet-600',
    title: 'Mapeamento de Ecossistema de Startups',
    summary: 'Análise de rede de colaboração entre startups, investidores e universidades para identificação de atores estratégicos e gaps de conexão.',
    metrics: ['200+ atores', 'Rede bipartida', 'Relatório estratégico'],
  },
  {
    seed: 9,
    tag: 'P&D',
    tagColor: 'bg-emerald-50 text-emerald-600',
    title: 'Redes de Co-Patentes e Inovação Aberta',
    summary: 'Mapeamento de fluxos de conhecimento tecnológico entre empresas, universidades e centros de pesquisa via análise de co-autoria de patentes.',
    metrics: ['Dados INPI', 'Análise temporal', 'Dashboard interativo'],
  },
];
---

<Layout title="Cases" description="Projetos de análise de redes e consultoria de Vinicius Santos para empresas e governos.">

  <section class="pt-32 pb-20 bg-navy-900">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-accent-cyan text-sm font-mono uppercase tracking-widest mb-4">Cases</p>
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">Projetos</h1>
      <p class="text-gray-400 text-xl max-w-2xl">
        Problema → dados → rede → decisão. Cada projeto aqui seguiu esse ciclo completo.
      </p>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-6 space-y-6">
      {cases.map((c, i) => (
        <div class="group grid md:grid-cols-5 rounded-2xl border border-gray-100 overflow-hidden hover:border-accent hover:shadow-xl transition-all duration-300">

          <!-- Network preview -->
          <div class="md:col-span-2 relative bg-navy-900 min-h-64">
            <div class="absolute inset-0 transition-opacity duration-300"
                 style="background:radial-gradient(ellipse at 50% 50%, rgba(59,130,246,0.15) 0%, transparent 70%)">
            </div>
            <MiniNetwork client:visible seed={c.seed} hovered={true} />
            <span class={`absolute top-4 left-4 px-2.5 py-1 text-xs font-semibold rounded-full ${c.tagColor}`}>
              {c.tag}
            </span>
          </div>

          <!-- Content -->
          <div class="md:col-span-3 p-8 flex flex-col justify-between bg-white group-hover:bg-gray-50 transition-colors duration-300">
            <div>
              <h2 class="text-2xl font-bold text-navy-900 mb-3 group-hover:text-accent transition-colors duration-200">
                {c.title}
              </h2>
              <p class="text-gray-600 leading-relaxed mb-6">{c.summary}</p>
              <div class="flex flex-wrap gap-2">
                {c.metrics.map(m => (
                  <span class="px-3 py-1 bg-gray-100 text-gray-600 text-sm rounded-full">{m}</span>
                ))}
              </div>
            </div>
            <div class="mt-8 pt-6 border-t border-gray-100">
              <a href={`${base}/consulting`}
                 class="inline-flex items-center gap-2 text-accent font-medium text-sm hover:gap-3 transition-all">
                Projeto similar? Vamos conversar
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
            </div>
          </div>

        </div>
      ))}
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold text-navy-900 mb-4">Tem um problema parecido?</h2>
      <p class="text-gray-600 mb-8">A maioria dos projetos começa com uma pergunta que ninguém sabe responder com os dados disponíveis.</p>
      <a href={`${base}/consulting`} class="inline-flex items-center px-8 py-4 bg-accent text-white font-semibold rounded-xl hover:bg-blue-600 transition-colors">
        Falar sobre seu projeto
      </a>
    </div>
  </section>

</Layout>
