---
import Layout from '../../layouts/Layout.astro';
import SectionNetwork from '../../components/SectionNetwork.jsx';
const base = import.meta.env.BASE_URL;

const cases = [
  {
    seed: 1,
    tag: 'Governo',
    title: 'Monitoramento Legislativo com NLP',
    summary: 'Processamento de 14 anos de notas taquigráficas do Senado Federal para mapear coalizões e orientar posicionamento parlamentar.',
    metrics: ['14 anos de dados', '27 comissões', 'NLP + redes'],
    tall: true,
  },
  {
    seed: 4,
    tag: 'Inovação',
    title: 'Mapeamento de Ecossistema de Startups',
    summary: 'Análise de rede de colaboração entre startups, investidores e universidades para identificação de atores estratégicos.',
    metrics: ['200+ atores', 'Rede bipartida', 'Relatório estratégico'],
    tall: false,
  },
  {
    seed: 9,
    tag: 'P&D',
    title: 'Redes de Co-Patentes e Inovação Aberta',
    summary: 'Mapeamento de fluxos de conhecimento tecnológico entre empresas, universidades e centros de pesquisa via análise de co-autoria de patentes.',
    metrics: ['Dados INPI', 'Análise temporal', 'Dashboard interativo'],
    tall: true,
  },
];
---

<Layout title="Cases" description="Projetos de análise de redes e consultoria de Vinicius Santos para empresas e governos.">

  <!-- Header editorial -->
  <section class="pt-32 pb-0 bg-stone-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-start justify-between mb-16">
        <div class="flex items-center gap-2 pt-2">
          <span class="w-2 h-2 bg-navy-900 rounded-none inline-block"></span>
          <span class="text-xs font-mono uppercase tracking-widest text-navy-900">Projetos</span>
        </div>
        <h1 class="text-5xl md:text-8xl font-bold text-navy-900 tracking-tight leading-none text-right">
          NOSSOS<br/>PROJETOS.
        </h1>
      </div>
    </div>
  </section>

  <!-- Grid assimétrico -->
  <section class="bg-stone-50 pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-12 gap-4 items-end">

        <!-- Case 1 — tall, 4 colunas -->
        <div class="col-span-12 md:col-span-4 group">
          <a href={`${base}/consulting`} class="block">
            <div class="relative overflow-hidden rounded-2xl bg-navy-900 mb-4" style="height: 520px;">
              <SectionNetwork client:visible seed={cases[0].seed} />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-900/80 to-transparent"></div>
              <span class="absolute top-4 left-4 px-2.5 py-1 bg-white/10 backdrop-blur-sm text-white text-xs font-medium rounded-full border border-white/20">
                {cases[0].tag}
              </span>
              <div class="absolute bottom-5 right-5 w-10 h-10 bg-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                <svg class="w-4 h-4 text-navy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </div>
            </div>
            <h2 class="font-mono text-sm text-navy-900 group-hover:text-accent transition-colors leading-snug mb-2">
              {cases[0].title}
            </h2>
            <p class="text-xs text-stone-500 leading-relaxed">{cases[0].summary}</p>
          </a>
        </div>

        <!-- Case 2 — curto, 4 colunas, deslocado para baixo -->
        <div class="col-span-12 md:col-span-4 group md:mt-32">
          <a href={`${base}/consulting`} class="block">
            <div class="relative overflow-hidden rounded-2xl bg-navy-900 mb-4" style="height: 340px;">
              <SectionNetwork client:visible seed={cases[1].seed} />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-900/80 to-transparent"></div>
              <span class="absolute top-4 left-4 px-2.5 py-1 bg-white/10 backdrop-blur-sm text-white text-xs font-medium rounded-full border border-white/20">
                {cases[1].tag}
              </span>
              <div class="absolute bottom-5 right-5 w-10 h-10 bg-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                <svg class="w-4 h-4 text-navy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </div>
            </div>
            <h2 class="font-mono text-sm text-navy-900 group-hover:text-accent transition-colors leading-snug mb-2">
              {cases[1].title}
            </h2>
            <p class="text-xs text-stone-500 leading-relaxed">{cases[1].summary}</p>
          </a>
        </div>

        <!-- Case 3 — tall, 4 colunas -->
        <div class="col-span-12 md:col-span-4 group">
          <a href={`${base}/consulting`} class="block">
            <div class="relative overflow-hidden rounded-2xl bg-navy-900 mb-4" style="height: 460px;">
              <SectionNetwork client:visible seed={cases[2].seed} />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-900/80 to-transparent"></div>
              <span class="absolute top-4 left-4 px-2.5 py-1 bg-white/10 backdrop-blur-sm text-white text-xs font-medium rounded-full border border-white/20">
                {cases[2].tag}
              </span>
              <div class="absolute bottom-5 right-5 w-10 h-10 bg-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                <svg class="w-4 h-4 text-navy-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </div>
            </div>
            <h2 class="font-mono text-sm text-navy-900 group-hover:text-accent transition-colors leading-snug mb-2">
              {cases[2].title}
            </h2>
            <p class="text-xs text-stone-500 leading-relaxed">{cases[2].summary}</p>
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold text-navy-900 mb-4">Tem um problema parecido?</h2>
      <p class="text-gray-600 mb-8">A maioria dos projetos começa com uma pergunta que ninguém sabe responder com os dados disponíveis.</p>
      <a href={`${base}/consulting`} class="inline-flex items-center px-8 py-4 bg-accent text-white font-semibold rounded-xl hover:bg-blue-600 transition-colors">
        Falar sobre seu projeto
      </a>
    </div>
  </section>

</Layout>
