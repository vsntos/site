---
interface Props { base: string; }
const { base } = Astro.props;
const currentPath = Astro.url.pathname;

const links = [
  { href: `${base}/research`, label: 'Pesquisa' },
  { href: `${base}/cases`, label: 'Cases' },
  { href: `${base}/blog`, label: 'Blog' },
  { href: `${base}/about`, label: 'Sobre' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href={base || '/'} class="font-semibold text-navy-900 text-lg tracking-tight hover:text-accent transition-colors">
      Vinicius Santos
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class={`text-sm font-medium transition-colors ${
            currentPath.startsWith(link.href)
              ? 'text-accent'
              : 'text-gray-600 hover:text-gray-900'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href={`${base}/consulting`}
      class="hidden md:inline-flex items-center px-4 py-2 bg-accent text-white text-sm font-medium rounded-lg hover:bg-blue-600 transition-colors"
    >
      Consultoria
    </a>

    <button id="menu-btn" class="md:hidden p-2 text-gray-600" aria-label="Menu">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4">
      {links.map(link => (
        <a href={link.href} class="text-sm font-medium text-gray-700 hover:text-accent transition-colors">
          {link.label}
        </a>
      ))}
      <a href={`${base}/consulting`} class="text-sm font-medium text-accent">
        Consultoria →
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
